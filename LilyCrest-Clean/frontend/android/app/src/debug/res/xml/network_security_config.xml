<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Debug builds need HTTP access to the Metro/dev server on the local LAN. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
